# Single-user authentication
AUTH_SECRET=replace-with-at-least-32-random-characters
ADMIN_PASSWORD=change-me
# ADMIN_PASSWORD_HASH=$2b$12$...

# DeepSeek (the app uses a deterministic demo generator when omitted)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.8
NEXT_PUBLIC_DEEPSEEK_ENABLED=false

# PostgreSQL / Redis
DATABASE_URL=postgresql://sparkreel:sparkreel@postgres:5432/sparkreel?schema=public
REDIS_URL=redis://redis:6379

# S3-compatible storage (MinIO in docker-compose)
S3_ENDPOINT=http://minio:9000
S3_REGION=auto
S3_BUCKET=sparkreel
S3_ACCESS_KEY_ID=sparkreel
S3_SECRET_ACCESS_KEY=change-this-minio-secret
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000/sparkreel

# Native media tools used by the worker
FFMPEG_PATH=/usr/bin/ffmpeg
EDGE_TTS_PATH=/usr/local/bin/edge-tts
EDGE_TTS_VOICE=zh-CN-XiaoyiNeural
EDGE_TTS_RATE=-5%
PIPER_PATH=/usr/local/bin/piper
PIPER_MODEL=/models/zh_CN-huayan-medium.onnx
PEXELS_API_KEY=
RENDER_CONCURRENCY=1
ALLOW_MOCK_RENDER=false
